FROM node:20-alpine AS base
WORKDIR /app

FROM base AS build
COPY src/Scraper/package.json src/Scraper/package-lock.json* ./
RUN npm ci
COPY src/Scraper/ .
RUN npm run build

FROM base AS final
WORKDIR /app
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY src/Scraper/package.json ./
CMD ["node", "dist/worker.js"]
